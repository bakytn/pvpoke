    {
        "speciesId": "altaria",
        "fastMove": "DRAGON_BREATH",
        "chargedMoves": [
            "SKY_ATTACK",
            "FLAMETHROWER"
        ],
        "weight": 23,
        "editorScore": 94,
        "editorNotes": "Altaria's flexibility with Flamethrower gives it coverage against Steel types, and its defensive typing remains one of the best to counter Water and Ground types. It's seeing more play this season with the nerf to its nemesis, Wigglytuff."
    },
    {
        "speciesId": "lapras",
        "fastMove": "PSYWAVE",
        "chargedMoves": [
            "SPARKLING_ARIA",
            "ICE_BEAM"
        ],
        "weight": 5,
        "editorScore": 90,
        "editorNotes": "Lapras has a long competitive history, but is currently on its way out of the metagame. It's a poster child for bulky Water types and neutral play. Recent shifts have left it without a clear role, and it now faces stiff competition among Water/Ice types."
    },
    {
        "speciesId": "golisopod",
        "fastMove": "FURY_CUTTER",
        "chargedMoves": [
            "AQUA_JET",
            "X_SCISSOR"
